# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session — random 32-byte hex secret for HMAC signing
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Cron — secret Vercel sends as "Authorization: Bearer <value>" on cron calls
# Set the same value in your Vercel project environment variables
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional — floating map button on user page (omit to hide)
NEXT_PUBLIC_SHOP_COORDINATES=    # e.g. 1.5674732,110.3262
